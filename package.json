{
  "name": "bolaji",
  "version": "0.1.0",
  "private": true,
  "description": "Portfolio of Bolaji Adekunle — frontend / product engineer.",
  "scripts": {
    "dev": "concurrently -k -n velite,next -c yellow,cyan \"velite --watch\" \"next dev --turbo\"",
    "build": "velite && next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,css,md,mdx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,md,mdx,json}\""
  },
  "dependencies": {
    "@shikijs/transformers": "^4.1.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "geist": "^1.3.1",
    "gsap": "^3.12.5",
    "lenis": "^1.1.20",
    "lucide-react": "^0.469.0",
    "motion": "^11.15.0",
    "next": "^15.1.0",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "shiki": "^4.1.0",
    "tailwind-merge": "^2.5.5",
    "velite": "^0.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  }
}
